# ── Animals Service Environment ──────────────────────────────
# These are resolved automatically from vault-service.
# Only needed if running without vault.

ANIMALS_SERVICE_PORT=5616
MONGO_URI=mongodb://localhost:27017/animals
VAULT_SERVICE_URL=http://localhost:5599
VAULT_TOKEN=your-vault-token-here

# ── Admin guard (write endpoints; empty = disabled) ──────────
ANIMALS_SERVICE_API_SECRET=

# ── Adoption data sources (optional; sync skips unconfigured) ─
PETFINDER_API_KEY=
PETFINDER_API_SECRET=
RESCUEGROUPS_API_KEY=

# ── Giving providers (optional) ──────────────────────────────
EVERYORG_PUBLIC_KEY=
EVERYORG_WEBHOOK_TOKEN=
GLOBALGIVING_API_KEY=

# ── Sync tuning ──────────────────────────────────────────────
ANIMALS_SYNC_INTERVAL_MINUTES=360
ANIMALS_SYNC_MAX_PAGES=5
